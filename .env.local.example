# Supabase 接続情報
# Supabase ダッシュボード > Project Settings > API から取得して .env.local にコピーする
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ISRの手動再検証用シークレット（POST /api/revalidate?secret=... で使用）
REVALIDATE_SECRET=your-revalidate-secret

# お問い合わせ・削除依頼フォーム（WBS 2.4のGoogleフォームURL。未設定なら「準備中」表示）
NEXT_PUBLIC_CONTACT_FORM_URL=
